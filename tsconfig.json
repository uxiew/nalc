{
  "compilerOptions": {
    "target": "es5",
    "lib": [
      "es2015"
    ],
    "module": "esnext",
    "moduleResolution": "bundler",
    "declaration": true,
    "sourceMap": true,
    "strictNullChecks": true,
    "esModuleInterop": true,
    "strict": true,
    "noImplicitThis": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "allowJs": false,
    "newLine": "LF",
    "skipLibCheck": true,
    "outDir": "lib"
  },
  "include": [
    "src"
  ],
  "formatCodeOptions": {
    "indentSize": 2,
    "tabSize": 2
  }
}