{
  "name": "@xwai/nalc",
  "version": "0.0.2",
  "description": "Registry-first local package development through an embedded Verdaccio proxy.",
  "homepage": "https://github.com/uxiew/nalc",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/uxiew/nalc.git"
  },
  "type": "module",
  "bin": {
    "nalc": "dist/nalc.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "pnpm clean && tsc && ts-add-js-extension --dir=dist && node before_publish.js",
    "clean": "ts-clean-built --all --out dist && trash  **/*.log",
    "prepublishOnly": "pnpm clean && pnpm build && pnpm test",
    "test": "vitest run",
    "test-dev": "vitest",
    "ci": "pnpm build && pnpm test"
  },
  "husky": {
    "hooks": {
      "pre-commit": "pnpm test && pretty-quick --staged"
    }
  },
  "dependencies": {
    "@publint/pack": "^0.1.2",
    "detect-indent": "^7.0.2",
    "fast-glob": "^3.3.3",
    "fs-extra": "^11.3.3",
    "ini": "^6.0.0",
    "picocolors": "^1.1.1",
    "verdaccio": "^6.2.9",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@types/chai": "^5.2.3",
    "@types/fs-extra": "^11.0.4",
    "@types/ini": "^4.1.1",
    "@types/js-yaml": "^4.0.9",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.0.3",
    "@types/yargs": "^17.0.35",
    "chokidar": "^5.0.0",
    "clean-ts-built": "^1.0.0",
    "husky": "^9.1.7",
    "prettier": "^3.7.4",
    "pretty-quick": "^4.2.2",
    "replace-in": "^1.0.0",
    "trash-cli": "^7.0.0",
    "ts-add-js-extension": "^1.6.6",
    "ts-clean-built": "^1.3.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16"
  },
  "license": "MIT"
}
